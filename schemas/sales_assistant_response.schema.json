{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SalesAssistantResponse",
  "type": "object",
  "required": [
    "customer_intent",
    "scene",
    "budget_range",
    "taste_preference",
    "recommended_products",
    "recommendation_reasons",
    "objection_strategy",
    "suggested_pitch",
    "follow_up_questions",
    "confidence",
    "evidence_sources"
  ],
  "properties": {
    "customer_intent": {
      "type": "string",
      "enum": [
        "self_drink",
        "gift",
        "business_gift",
        "compare",
        "price_question",
        "beginner_help"
      ]
    },
    "scene": {
      "type": "string",
      "enum": [
        "self_drink",
        "gift_leader",
        "gift_elder",
        "business_visit",
        "collect",
        "beginner_help"
      ]
    },
    "budget_range": {
      "type": "string"
    },
    "taste_preference": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "product_id",
          "product_name",
          "fit_score",
          "reason_points",
          "suggested_pitch",
          "risk_notes"
        ],
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "fit_score": {
            "type": "number"
          },
          "reason_points": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "suggested_pitch": {
            "type": "string"
          },
          "risk_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "recommendation_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "objection_strategy": {
      "type": "object",
      "required": [
        "type",
        "logic_points",
        "suggested_pitch"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "logic_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggested_pitch": {
          "type": "string"
        }
      }
    },
    "suggested_pitch": {
      "type": "string"
    },
    "follow_up_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}